{
  "name": "fortigate-ha-infra",
  "version": "0.1.0",
  "description": "FortiGate HA on AWS — CDK infrastructure",
  "private": true,
  "scripts": {
    "build":   "tsc --noEmit",
    "synth":   "npx cdk synth",
    "test":    "jest",
    "deploy":  "npx cdk deploy --all",
    "destroy": "npx cdk destroy --all"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.170.0",
    "constructs":  "^10.0.0"
  },
  "devDependencies": {
    "typescript":  "^5.4.0",
    "ts-node":     "^10.9.0",
    "@types/node": "^20.0.0",
    "jest":        "^29.0.0",
    "ts-jest":     "^29.0.0",
    "@types/jest": "^29.0.0",
    "aws-cdk":     "^2.170.0"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": ["<rootDir>/test"],
    "testMatch": ["**/*.test.ts"],
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    }
  }
}
