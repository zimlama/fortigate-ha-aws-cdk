{
  "compilerOptions": {
    "strict":           true,
    "target":           "ES2020",
    "module":           "commonjs",
    "lib":              ["ES2020"],
    "esModuleInterop":  true,
    "rootDir":          "./",
    "outDir":           "dist",
    "skipLibCheck":     true,
    "declaration":      true,
    "inlineSourceMap":  true,
    "inlineSources":    true
  },
  "exclude": ["node_modules", "dist"]
}
